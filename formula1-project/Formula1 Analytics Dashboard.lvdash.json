    {
      "name": "19108b75",
      "displayName": "Dominant Drivers of All time",
      "queryLines": [
        "with drivers_metrics as\r\n",
        "(select driver_name,\r\n",
        "sum(race_starts) as race_starts,\r\n",
        "sum(total_points) as total_points,\r\n",
        "sum(number_of_wins) as Total_wins,\r\n",
        "sum(number_of_podiums) as Total_podiums,\r\n",
        "sum(case when standings=1 then 1 else 0 end) as Total_championships\r\n",
        "from formula1.gold.v_driver_standing \r\n",
        "group by driver_name\r\n",
        "having total_championships>=1  )\r\n",
        "\r\n",
        "select driver_name,\r\n",
        "race_starts,\r\n",
        "total_points,\r\n",
        "Total_wins,\r\n",
        "Total_podiums,\r\n",
        "Total_championships,\r\n",
        "(total_championships*100)+(Total_wins*10)+(Total_podiums*3) as greatness_Score\r\n",
        "from drivers_metrics\r\n",
        "order by greatness_score desc\r\n",
        "limit 10;"
      ]
    },
    {
      "name": "a94ee44d",
      "displayName": "Dominant Constructors of All time",
      "queryLines": [
        "with constructors_metrics as\r\n",
        "(select constructor_name,\r\n",
        "sum(race_starts) as race_starts,\r\n",
        "sum(total_points) as total_points,\r\n",
        "sum(number_of_wins) as Total_wins,\r\n",
        "sum(number_of_podiums) as Total_podiums,\r\n",
        "sum(case when standings=1 then 1 else 0 end) as Total_championships\r\n",
        "from formula1.gold.v_constructor_standing \r\n",
        "group by constructor_name\r\n",
        "having total_championships>=1  )\r\n",
        "\r\n",
        "select constructor_name,\r\n",
        "race_starts,\r\n",
        "total_points,\r\n",
        "Total_wins,\r\n",
        "Total_podiums,\r\n",
        "Total_championships,\r\n",
        "(total_championships*100)+(Total_wins*10)+(Total_podiums*3) as greatness_Score\r\n",
        "from constructors_metrics\r\n",
        "order by greatness_score desc\r\n",
        "limit 10;"
      ]
    }
  ],
